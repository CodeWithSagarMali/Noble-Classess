datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enums removed for SQLite compatibility. Standard string values are used.


model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  passwordHash         String
  role                 String         @default("STUDENT")
  isVerified           Boolean        @default(false)
  verificationToken    String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  refreshToken         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  studentProfile       StudentProfile?
  teacherProfile       TeacherProfile?
  auditLogs            AuditLog[]
  blogPosts            BlogPost[]
  supportReplies       SupportReply[]
}

model StudentProfile {
  id               String          @id @default(uuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  phone            String
  parentName       String
  parentPhone      String
  address          String
  dateOfBirth      DateTime
  gender           String
  rollNumber       String?         @unique
  admissionNo      String?         @unique
  passportPhotoUrl String?
  aadhaarUrl       String?
  marksheetUrl     String?
  batchId          String?
  batch            Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  status           String          @default("PENDING")
  paymentStatus    String          @default("PENDING")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  attendance       Attendance[]
  feePayments      FeePayment[]
  examResults      ExamResult[]
  supportTickets   SupportTicket[]
}

model TeacherProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  phone          String
  specialization String
  qualifications String
  experience     String
  bio            String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  batches        Batch[]
}

model Course {
  id             String          @id @default(uuid())
  name           String
  description    String
  durationMonths Int
  baseFee        Float
  syllabusLink   String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  batches        Batch[]
  studyMaterials StudyMaterial[]
}

model Batch {
  id            String           @id @default(uuid())
  name          String
  startTime     String
  endTime       String
  courseId      String
  course        Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId     String?
  teacher       TeacherProfile?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  students      StudentProfile[]
  attendance    Attendance[]
  exams         Exam[]
  announcements Announcement[]
}

model Attendance {
  id         String           @id @default(uuid())
  date       DateTime
  studentId  String
  student    StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batchId    String
  batch      Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  status     String
  uploadedBy String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([date, studentId, batchId])
}

model FeePayment {
  id               String        @id @default(uuid())
  studentId        String
  student          StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount           Float
  type             String
  mode             String
  status           String @default("PENDING")
  razorpayOrderId  String?
  razorpayPaymentId String?
  transactionRef   String?
  dueDate          DateTime
  paidAt           DateTime?
  invoiceUrl       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Exam {
  id              String       @id @default(uuid())
  title           String
  description     String
  durationMinutes Int
  totalMarks      Float
  negativeMarking Float        @default(0)
  batchId         String
  batch           Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  questions       Question[]
  results         ExamResult[]
}

model Question {
  id            String   @id @default(uuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   // 'A', 'B', 'C', 'D'
  positiveMarks Float    @default(4)
  negativeMarks Float    @default(1)
  createdAt     DateTime @default(now())
}

model ExamResult {
  id                 String         @id @default(uuid())
  examId             String
  exam               Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId          String
  student            StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  totalQuestions     Int
  attemptedQuestions Int
  correctAnswers     Int
  wrongAnswers       Int
  marksObtained      Float
  submittedAt        DateTime       @default(now())

  @@unique([examId, studentId])
}

model StudyMaterial {
  id             String   @id @default(uuid())
  title          String
  description    String
  fileUrl        String
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  uploadedBy     String
  downloadsCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Announcement {
  id             String       @id @default(uuid())
  title          String
  content        String
  targetAudience String       @default("ALL")
  batchId        String?
  batch          Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model BlogPost {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String
  coverImage String
  category  String
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryItem {
  id        String   @id @default(uuid())
  imageUrl  String
  albumName String
  caption   String?
  createdAt DateTime @default(now())
}

model Testimonial {
  id           String   @id @default(uuid())
  studentName  String
  studentImage String?
  courseName   String
  text         String
  rating       Int      @default(5)
  batchYear    String
  createdAt    DateTime @default(now())
}

model ContactEnquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  subject   String
  message   String
  status    String   @default("PENDING")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id          String         @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject     String
  description String
  priority    String         @default("MEDIUM")
  status      String         @default("OPEN")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  replies     SupportReply[]
}

model SupportReply {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime      @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  ipAddress String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}
