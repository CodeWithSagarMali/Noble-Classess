# Server configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database configuration (PostgreSQL)
# For local Docker setup: postgresql://noble_admin:noble_password@localhost:5432/noble_classes?schema=public
DATABASE_URL=postgresql://noble_admin:noble_password@localhost:5432/noble_classes?schema=public

# JWT authentication secrets
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_sign_key_change_me_in_prod
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_sign_key_change_me_in_prod

# AWS S3 compatible storage config (Leave empty to use local disk storage in 'backend/uploads/')
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET_NAME=noble-classes-assets

# Razorpay payments API (Leave empty to enable mock payment test mode)
# RAZORPAY_KEY_ID=rzp_test_xxxxxx
# RAZORPAY_KEY_SECRET=xxxxxx

# Email Configuration (for verification and alerts, SMTP configuration)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@nobleclasses.com
